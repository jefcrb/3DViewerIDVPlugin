<Page x:Class="neo_bpsys_wpf._3DViewerIDV.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="3DViewerIDV Settings">

    <StackPanel Margin="20" MaxWidth="400" HorizontalAlignment="Left">
        <ui:CardControl>
            <StackPanel Margin="16">
                <TextBlock Text="OBS Browser Source / OBS浏览器源"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,15"/>

                <!-- Port input -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Port:"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                    <ui:NumberBox Grid.Column="1"
                                  Value="{Binding PortInput, Mode=TwoWay}"
                                  Minimum="1024"
                                  Maximum="65535"
                                  SpinButtonPlacementMode="Inline"
                                  HorizontalAlignment="Stretch"/>
                </Grid>

                <!-- Start/Stop button -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ui:Button Content="Start Server"
                               Command="{Binding StartServerCommand}"
                               Appearance="Primary"
                               Icon="{ui:SymbolIcon Play24}"
                               Margin="0,0,10,0">
                        <ui:Button.Style>
                            <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                <Setter Property="IsEnabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:Button.Style>
                    </ui:Button>

                    <ui:Button Content="Stop Server"
                               Command="{Binding StopServerCommand}"
                               Appearance="Secondary"
                               Icon="{ui:SymbolIcon Stop24}"
                               IsEnabled="{Binding IsServerRunning}"/>
                </StackPanel>

                <!-- Server url -->
                <TextBlock>
                    <Hyperlink Command="{Binding OpenServerUrlCommand}"
                               TextDecorations="None">
                        <TextBlock Text="{Binding ServerUrl}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </ui:CardControl>
    </StackPanel>
</Page>
